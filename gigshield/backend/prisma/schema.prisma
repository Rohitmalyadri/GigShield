generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Worker {
  id                    String   @id @default(uuid())
  workerHash            String   @unique
  name                  String   @default("Unknown Partner")
  platforms             String[]
  zone                  String
  city                  String
  weeklyEarningsHistory Float[]
  currentWeeklyPremium  Float    @default(0)
  zoneRiskScore         Float    @default(1.0)
  seasonalMultiplier    Float    @default(1.0)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  policies              Policy[]
  claims                Claim[]
  activities            WorkerActivity[]
  compensations         Compensation[]
}

model Policy {
  id             String   @id @default(uuid())
  workerId       String
  worker         Worker   @relation(fields: [workerId], references: [id])
  weekStartDate  DateTime
  weekEndDate    DateTime
  premiumAmount  Float
  premiumPaid    Boolean  @default(false)
  coverageActive Boolean  @default(true)
  createdAt      DateTime @default(now())
  claims         Claim[]
}

model Claim {
  id                  String   @id @default(uuid())
  workerId            String
  worker              Worker   @relation(fields: [workerId], references: [id])
  policyId            String
  policy              Policy   @relation(fields: [policyId], references: [id])
  disruptionType      String
  gate1Passed         Boolean  @default(false)
  gate2Passed         Boolean  @default(false)
  fraudCheckPassed    Boolean  @default(false)
  payoutAmount        Float    @default(0)
  payoutStatus        String   @default("pending")
  disruptionStartTime DateTime
  disruptionEndTime   DateTime?
  hoursLost           Float    @default(0)
  createdAt           DateTime @default(now())
}

model DisruptionEvent {
  id             String    @id @default(uuid())
  zone           String
  eventType      String
  severity       String
  confirmedByApi Boolean   @default(false)
  apiSource      String
  startTime      DateTime
  endTime        DateTime?
  isResolved     Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

model AnomalyArchetype {
  id             String   @id @default(uuid())
  signatureHash  String   @unique
  description    String
  confirmations  Int      @default(0)
  isAutoTrigger  Boolean  @default(false)
  createdAt      DateTime @default(now())
}

// ── STEP 4: Dynamic Risk Protection Engine models ─────────

// Stores the calculated risk score per zone after each evaluation.
// Queried by GET /api/risk/score/:zoneId
model ZoneRisk {
  id          String   @id @default(uuid())
  zoneId      String                         // Pin code (e.g. "560034")
  city        String   @default("Unknown")
  riskScore   Float                          // 0–100 composite score
  // Component scores for transparency/audit
  weatherScore    Float @default(0)
  workerShortage  Float @default(0)
  demandSurge     Float @default(0)
  regulatoryRisk  Float @default(0)
  // Decision output
  decisionMode    String @default("NORMAL") // NORMAL | INCENTIVE | PROTECTION | CRITICAL
  timestamp   DateTime @default(now())

  @@index([zoneId])
  @@index([timestamp])
}

// Tracks per-worker activity metrics used in eligibility checks.
model WorkerActivity {
  id               String   @id @default(uuid())
  workerId         String
  worker           Worker   @relation(fields: [workerId], references: [id])
  zoneId           String
  activeHours      Float    @default(0)        // Hours online during the risk window
  completedOrders  Int      @default(0)        // Orders fulfilled in the window
  avgOrdersPerHour Float    @default(0)        // Baseline for demand surge calc
  sessionDate      DateTime @default(now())    // Which day/shift this covers
  createdAt        DateTime @default(now())

  @@index([workerId])
  @@index([zoneId])
}

// Records every compensation decision, whether paid or pending.
model Compensation {
  id          String   @id @default(uuid())
  workerId    String
  worker      Worker   @relation(fields: [workerId], references: [id])
  zoneId      String
  amount      Float                            // In rupees
  type        String                           // BONUS | GUARANTEE | DOWNTIME
  status      String   @default("PENDING")     // PENDING | PAID | REJECTED
  riskScore   Float    @default(0)             // Score at time of decision
  reason      String?                          // Human-readable explanation
  createdAt   DateTime @default(now())

  @@index([workerId])
  @@index([status])
}

// Tracks the shared risk pool for financial sustainability logic.
model PremiumPool {
  id             String   @id @default(uuid())
  totalCollected Float    @default(0)  // Total premiums collected (₹)
  totalPayout    Float    @default(0)  // Total compensation paid out (₹)
  lossRatio      Float    @default(0)  // totalPayout / totalCollected
  lastUpdated    DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model Payment {
  id          String   @id @default(uuid())
  orderId     String   @unique        // Razorpay order ID (order_XXXXXXXXX)
  paymentId   String?                 // Razorpay payment ID (pay_XXXXXXXXX) — set after success
  signature   String?                 // HMAC SHA256 signature — stored for audit trail
  amount      Int                     // In paise (₹100 = 10000 paise)
  currency    String   @default("INR")
  status      String   @default("PENDING")  // PENDING | SUCCESS | FAILED
  workerHash  String?                 // Optional: link payment to a specific worker
  description String?                 // What the payment is for (e.g. "Weekly premium")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
